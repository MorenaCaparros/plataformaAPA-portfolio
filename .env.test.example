# Variables de entorno para tests locales
# =========================================
# Copiá este archivo a .env.test y completá con valores reales
# de tu proyecto Supabase de TEST (NO usar el proyecto de producción).
#
# NUNCA commitear .env.test con valores reales.

# ── Supabase LOCAL (Supabase CLI + Docker) ─────────────────────
# Levantá con: npx supabase start
# Luego: npx supabase status → copiá los valores
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=<obtenér de "npx supabase status">
SUPABASE_SERVICE_ROLE_KEY=<obtenér de "npx supabase status">

# ── Supabase CLOUD de STAGING (alternativa a local) ────────────
# Crear un nuevo proyecto en https://supabase.com para testing.
# Nombrarlo: "plataformaAPA-test" o "plataformaAPA-staging"
# NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto-test.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key-de-test

# ── Google AI (Gemini) ─────────────────────────────────────────
# Podés usar la misma key para tests porque los tests mockean la API
GOOGLE_AI_API_KEY=placeholder-mocked-in-tests

# ── Encriptación ───────────────────────────────────────────────
# Clave de 32 bytes en base64 (generá una nueva para tests):
# node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ENCRYPTION_KEY=testkeybase64paraencriptaciontest