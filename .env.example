# Variables de entorno - Plataforma APA
# ⚠️ NUNCA commitear valores reales - este es solo un template

# ==================================
# SUPABASE
# ==================================
# Obtener en: https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key-publica

# ⚠️ NUNCA EXPONER - Solo para backend
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key-privada

# ==================================
# GOOGLE AI (GEMINI) - GRATIS
# ==================================
# Obtener en: https://aistudio.google.com/apikey
# Plan gratuito: 15 requests/minuto
GOOGLE_AI_API_KEY=tu-google-ai-api-key

# ==================================
# OPENROUTER - FALLBACK GRATUITO
# ==================================
# Si Gemini tiene rate limit o falla, el sistema cae automáticamente a OpenRouter.
# Obtener key gratis en: https://openrouter.ai/keys
# Modelo usado: google/gemini-2.0-flash-exp:free (sin costo)
OPENROUTER_API_KEY=tu-openrouter-api-key

# Tope de llamadas diarias a IA (aplica a Gemini + OpenRouter combinados)
GEMINI_MAX_DAILY_CALLS=300

# Límites por usuario
# Máximo de consultas por usuario en 1 hora
GEMINI_MAX_PER_USER_HORA=10
# Minutos mínimos entre consultas del mismo usuario
GEMINI_MIN_MINUTOS_ENTRE=10

# ==================================
# ENCRIPTACIÓN (para datos sensibles de menores)
# ==================================
# Generar con uno de estos comandos:
# Node: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# PowerShell: [Convert]::ToBase64String((1..32 | ForEach-Object { Get-Random -Minimum 0 -Maximum 256 }))
ENCRYPTION_KEY=tu-clave-de-encriptacion-base64

# ==================================
# GOOGLE DRIVE (opcional - para biblioteca)
# ==================================
# Crear Service Account en: https://console.cloud.google.com/iam-admin/serviceaccounts
# 1. Crear Service Account
# 2. Crear clave JSON y extraer email y private_key
# 3. Compartir carpeta de Drive con el email del Service Account
# 4. Obtener ID de la carpeta de la URL: https://drive.google.com/drive/folders/TU_FOLDER_ID
GOOGLE_SERVICE_ACCOUNT_EMAIL=tu-service-account@tu-proyecto.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
GOOGLE_DRIVE_FOLDER_ID=tu-folder-id-de-drive

# ==================================
# GOOGLE DRIVE - OAuth2 (opcional - para subir archivos)
# ==================================
# Crear credenciales OAuth2 en: https://console.cloud.google.com/apis/credentials
GOOGLE_DRIVE_CLIENT_ID=tu-client-id.apps.googleusercontent.com
GOOGLE_DRIVE_CLIENT_SECRET=tu-client-secret
GOOGLE_DRIVE_REDIRECT_URI=http://localhost:3000/api/drive/auth/callback

# Carpetas de Drive para almacenamiento de archivos
NEXT_PUBLIC_DRIVE_FOLDER_FOTOS=tu-folder-id-fotos
NEXT_PUBLIC_DRIVE_FOLDER_AUDIOS=tu-folder-id-audios
# Server-side aliases (para APIs - no se exponen al browser)
DRIVE_FOLDER_FOTOS=tu-folder-id-fotos
DRIVE_FOLDER_AUDIOS=tu-folder-id-audios

# ==================================
# MODO DEMO (para explorar sin credenciales)
# ==================================
# true  → app funciona con datos ficticios internos, sin Supabase ni API Key
# false → requiere las credenciales de arriba
NEXT_PUBLIC_DEMO_MODE=false

# ==================================
# INSTRUCCIONES DE USO
# ==================================
# OPCIÓN A – Demo instantáneo (recomendado para explorar el proyecto):
#   1. cp .env.example .env.local
#   2. Setear NEXT_PUBLIC_DEMO_MODE=true
#   3. npm install && npm run dev     ← listo, sin configurar nada más
#
# OPCIÓN B – Con Supabase propio (experiencia completa):
#   1. Crear proyecto gratis en https://supabase.com
#   2. Ejecutar migraciones: supabase/migrations/ (en orden por fecha)
#   3. Ejecutar seed: SQL Editor → scripts/demo-seed.sql
#   4. Copiar URL y ANON KEY de Supabase Dashboard → Settings → API
#   5. Obtener GOOGLE_AI_API_KEY en https://aistudio.google.com/apikey (gratis)
#   6. npm run demo:seed-users
#   7. npm run dev
#
# NUNCA commitear .env.local
