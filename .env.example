# Variables de entorno - Plataforma APA
# ⚠️ NUNCA commitear valores reales - este es solo un template

# ==================================
# SUPABASE (obligatorio)
# ==================================
# Obtener en: https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key-publica

# ⚠️ NUNCA EXPONER AL BROWSER - Solo para backend/API routes
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key-privada

# ==================================
# GOOGLE AI (GEMINI) - obligatorio para IA
# ==================================
# Obtener en: https://aistudio.google.com/apikey  (gratis)
GOOGLE_AI_API_KEY=tu-google-ai-api-key

# ==================================
# OPENROUTER - fallback automático de IA
# ==================================
# Si Gemini falla o tiene rate limit, el sistema usa OpenRouter como fallback.
# Obtener key gratis en: https://openrouter.ai/keys
OPENROUTER_API_KEY=tu-openrouter-api-key

# ==================================
# ENCRIPTACIÓN (para datos sensibles de menores)
# ==================================
# Generar con: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ENCRYPTION_KEY=tu-clave-de-encriptacion-base64
